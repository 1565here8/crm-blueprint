# Server
NODE_ENV=production
PORT=3002
TRUST_PROXY=1
SESSION_SECRET=change-me-to-a-long-random-string-at-least-32-chars

# Bootstrap owner account (created on first run if no users exist)
# Required: set strong unique values before first run.
# Used only when the database has zero users (see server/db.ts bootstrapAdmin).
# If you already have an admin account, change credentials with:
#   npx tsx scripts/set-admin.ts <username> <password>
ADMIN_USERNAME=your-admin-username
ADMIN_PASSWORD=your-strong-password-here

PUBLIC_SITE_URL=https://www.curionilabs.com
ADMIN_URL=https://admin.curionilabs.com
CORS_ORIGINS=https://curionilabs.com,https://www.curionilabs.com,https://admin.curionilabs.com

# Search indexing — MUST stay 0 until broker handoff (no Google)
SEARCH_INDEXING_ENABLED=0

# Public www offline during rebrand (admin portal unaffected)
# PUBLIC_SITE_REBRANDING=1
# PUBLIC_SITE_OFFLINE=1

# Demo walkthrough HD narrator (ElevenLabs — optional)
# Get key: https://elevenlabs.io → Profile → API key
# Without this, demo uses browser TTS (robotic). With key: cinematic narrator voice.
ELEVENLABS_API_KEY=
# Optional override — default follows voice preset in demo (Documentary = Daniel)
# ELEVENLABS_DEMO_VOICE_ID=onwK4e9ZLuTAKqWW03F9
# ELEVENLABS_DEMO_MODEL=eleven_multilingual_v2

# Optional: Alpaca paper trading keys
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_PAPER=true

# --- Curioni Labs vendor license (production brokers) ---
# CRM phones home with domain + build version only — NO client data.
# Issue keys via Curioni Labs control API (see VENDOR-LICENSE.md).
# VENDOR_LICENSE_ENABLED=1
# VENDOR_LICENSE_URL=https://curionilabs.com/api/curionilabs/crm-license/heartbeat
# VENDOR_TENANT_ID=broker-slug
# VENDOR_LICENSE_KEY=clk-issued-by-curionilabs
# VENDOR_HEARTBEAT_INTERVAL_MIN=60
# VENDOR_LICENSE_GRACE_HOURS=72

# --- Admin perimeter (broker VPS) ---
# Hard override for owner console IPs (comma-separated). UI: System → Session settings.
# ADMIN_IP_ALLOWLIST=203.0.113.10,10.0.0.0/24
# STAFF_IP_ALLOWLIST=203.0.113.0/24
