# Trading Site Blueprint Environment
PORT=3001
NODE_ENV=development

# JWT for session auth (generate with: openssl rand -hex 32)
JWT_SECRET=your-256-bit-hex-secret-here
CSRF_SECRET=your-128-bit-hex-secret-here

# Admin access
ADMIN_SECRET=your-admin-secret-here

# Database (defaults to SQLite at .data/store.sqlite)
DATABASE_PATH=.data/store.sqlite

# For PostgreSQL, set DATABASE_URL instead:
# DATABASE_URL=postgres://user:pass@localhost:5432/dbname

# CORS origin for development
CORS_ORIGIN=http://localhost:5173

# Session
SESSION_DURATION_HOURS=24

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=30

# AI API keys (optional - for trading AI features)
GEMINI_API_KEY=
GROQ_API_KEY=
XAI_API_KEY=
OPENROUTER_API_KEY=

# Premium tier pricing (cent)
PREMIUM_PRICE_CENTS=2000

# VPS deploy target (set when deploying)
VPS_HOST=
VPS_ROOT_PASSWORD=
